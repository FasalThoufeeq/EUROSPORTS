<script>

function changeQuantity(cartId,proId,userId,count){

    console.log(proId+"this is product id");

    let quantity=parseInt(document.getElementById(proId).textContent)
    count=parseInt(count)

    $.ajax({
        url:"/change_quantity",
        method:"PUT",
        data:{user:userId, products:proId, cart:cartId, count:count, quantity:quantity},
        
        success:(response)=>{
            // alert(response)

            if(response.removed==true){

                alert("Do you want to remove this product from your cart ?")
                location.reload()


                // if(updQuantity==1){
                //     $('#less').prop('disabled',true)
                // }else{
                //     $('#less').prop('disabled',false)
                // }


            }else{


                updQuantity=quantity+count;
                document.getElementById(proId).innerHTML=updQuantity
                document.getElementById('totalAmount').innerHTML=response.totalAmount
                
                // console.log(subTotal);



            }


           

        }
    })

}




// remove cart

function removeCart(cart,product){

    $.ajax({
        url:"/remove_cart",
        method:"DELETE",
        data:{cart,product},
        success:(response)=>{

            
            console.log(response.removed);

            if(response.removed==true){

                alert("Do you want to remove this product from your cart")
                location.reload()

            }

        }
    })
}

</script>